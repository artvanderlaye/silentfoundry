  <script>
  (function(){
    var idx = 0;
    var total = 4;
    function update() {
      var slides = document.querySelectorAll('#v4slides .v4-car-slide');
      var dots = document.querySelectorAll('.v4-car-dots .v4-dot');
      var num = document.getElementById('v4n');
      slides.forEach(function(s,i){ s.classList.toggle('active', i===idx); });
      dots.forEach(function(d,i){ d.classList.toggle('active', i===idx); });
      if(num) num.textContent = idx+1;
    }
    window.v4Step = function(dir){ idx=(idx+dir+total)%total; update(); };
    window.v4Go = function(i){ idx=i; update(); };
  })();
  </script>
