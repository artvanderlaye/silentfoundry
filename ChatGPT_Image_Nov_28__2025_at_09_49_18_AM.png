  <style>
    .sw2-wrap { padding: 120px 48px 60px; }
    .sw2-eyebrow { font-size:0.68rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--accent); display:block; margin-bottom:16px; }
    .sw2-title { font-family:var(--font-display); font-size:clamp(3.5rem,6vw,7rem); letter-spacing:0.1em; text-transform:uppercase; color:rgba(244,241,236,0.85); line-height:0.88; }
    .sw2-body { font-size:clamp(0.9rem,1.2vw,1.05rem); line-height:1.8; color:rgba(244,241,236,0.5); font-weight:300; }
    .sw2-pill { display:inline-block; padding:5px 14px; border:0.5px solid rgba(200,169,110,0.3); font-size:0.62rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--accent); margin:0 4px 4px 0; }
    .sw2-sep { padding:20px 0 16px; }
    .sw2-sep-label { font-size:0.65rem; letter-spacing:0.25em; text-transform:uppercase; color:rgba(244,241,236,0.25); }
    .sw2-gold-div { width:1px; margin:0 52px; align-self:stretch; background:linear-gradient(to bottom,transparent,rgba(200,169,110,0.22),transparent); }

    /* Hero */
    .v4-hero { display:grid; grid-template-columns:3fr 2fr; gap:2px; margin-bottom:0; }
    .v4-hero-left { padding:48px; display:flex; flex-direction:column; justify-content:flex-end; background:#0a0a0a; }
    .v4-hero-right { position:relative; overflow:hidden; min-height:380px; background:#0d0d0d; }

    /* Carousel */
    .v4-car-slides { position:absolute; inset:0; }
    .v4-car-slide { position:absolute; inset:0; opacity:0; transition:opacity 0.55s ease; pointer-events:none; }
    .v4-car-slide.active { opacity:1; pointer-events:auto; }
    .v4-car-slide img { width:100%; height:100%; object-fit:cover; filter:brightness(0.8); display:block; }
    .v4-car-btn { position:absolute; top:50%; transform:translateY(-50%); z-index:20; background:rgba(10,10,10,0.75); border:0.5px solid rgba(200,169,110,0.3); color:rgba(244,241,236,0.75); width:44px; height:44px; cursor:pointer; transition:all 0.2s; font-size:1.1rem; display:flex; align-items:center; justify-content:center; }
    .v4-car-btn:hover { background:rgba(200,169,110,0.15); border-color:rgba(200,169,110,0.7); color:var(--accent); }
    .v4-car-prev { left:14px; }
    .v4-car-next { right:14px; }
    .v4-car-dots { position:absolute; bottom:14px; left:50%; transform:translateX(-50%); display:flex; gap:7px; z-index:20; }
    .v4-dot { width:6px; height:6px; border-radius:50%; background:rgba(244,241,236,0.25); cursor:pointer; transition:background 0.25s, transform 0.25s; border:none; padding:0; }
    .v4-dot.active { background:var(--accent); transform:scale(1.3); }
    .v4-car-count { position:absolute; top:14px; right:16px; font-size:0.6rem; letter-spacing:0.18em; color:rgba(244,241,236,0.4); z-index:20; font-family:var(--font-display); }

    /* Metrics */
    .v4-metrics { display:grid; grid-template-columns:1fr auto 1fr auto 1fr auto 1fr; align-items:center; padding:28px 48px; background:#0d0d0d; border-top:1px solid rgba(244,241,236,0.06); border-bottom:1px solid rgba(244,241,236,0.06); }
    .v4-metric { text-align:center; }
    .v4-metric-val { font-family:var(--font-display); font-size:2.2rem; letter-spacing:0.06em; color:var(--accent); display:block; line-height:1; }
    .v4-metric-lbl { font-size:0.6rem; letter-spacing:0.18em; text-transform:uppercase; color:rgba(244,241,236,0.3); display:block; margin-top:5px; }
    .v4-metric-div { width:1px; height:44px; background:linear-gradient(to bottom,transparent,rgba(200,169,110,0.2),transparent); }

    /* DNA rules */
    .v4-rules { display:grid; grid-template-columns:repeat(5,1fr); gap:2px; margin-bottom:2px; }
    .v4-rule { background:#0f0f0f; padding:24px 20px; border-bottom:2px solid transparent; transition:border-color 0.25s; }
    .v4-rule:hover { border-bottom-color:var(--accent); }
    .v4-rule-num { font-family:var(--font-display); font-size:3rem; color:rgba(200,169,110,0.1); line-height:1; display:block; margin-bottom:8px; }
    .v4-rule-name { font-size:0.62rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--accent); display:block; margin-bottom:6px; }
    .v4-rule-desc { font-size:0.78rem; line-height:1.6; color:rgba(244,241,236,0.38); }

    /* Products */
    .v4-products { display:grid; grid-template-columns:repeat(3,1fr); gap:2px; }
    .v4-prod { background:#0f0f0f; overflow:hidden; }
    .v4-prod-img { position:relative; overflow:hidden; }
    .v4-prod-img img { width:100%; aspect-ratio:4/3; object-fit:cover; filter:brightness(0.65); transition:filter 0.5s, transform 0.7s; display:block; }
    .v4-prod:hover .v4-prod-img img { filter:brightness(0.85); transform:scale(1.04); }
    .v4-prod-body { padding:24px; }
    .v4-prod-cat { font-size:0.58rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--accent); display:block; margin-bottom:6px; }
    .v4-prod-name { font-family:var(--font-display); font-size:1.4rem; letter-spacing:0.1em; text-transform:uppercase; color:rgba(244,241,236,0.82); margin-bottom:8px; }
    .v4-prod-desc { font-size:0.8rem; line-height:1.65; color:rgba(244,241,236,0.4); }

    @media(max-width:900px){
      .sw2-wrap { padding:80px 24px 48px; }
      .v4-hero { grid-template-columns:1fr; }
      .v4-hero-right { min-height:260px; }
      .v4-metrics { grid-template-columns:1fr 1fr; gap:24px; padding:24px; }
      .v4-metric-div { display:none; }
      .v4-rules { grid-template-columns:1fr 1fr; }
      .v4-products { grid-template-columns:1fr; }
    }
    @media(max-width:600px){
      .v4-rules { grid-template-columns:1fr; }
    }
  </style>

  <div class="sw2-wrap reveal">

