    <span>sfg.</span>
  </div>

  <script src="sf-scripts.js"></script>
  <script>
  // ── CAROUSEL MANUAL STEP ──
  (function() {
    var track = document.getElementById('engTrack');
    if (!track) return;
    var slideW = 0;
    var manualOffset = 0;

    function getSlideWidth() {
      var slide = track.querySelector('.eng-slide');
      if (!slide) return 0;
      return slide.offsetWidth + 2;
    }

    window.engCarouselStep = function(dir) {
      if (!slideW) slideW = getSlideWidth();
      // Pause auto-scroll
      track.classList.add('paused');
      // Get current translate from animation or manual
      var style = window.getComputedStyle(track);
      var matrix = style.transform;
      var currentX = 0;
      if (matrix && matrix !== 'none') {
        var m = matrix.match(/matrix.*\((.+)\)/);
        if (m) currentX = parseFloat(m[1].split(', ')[6] || 0);
      }
      manualOffset = currentX - (dir * slideW);
      // Clamp so we don't go past the half-point (one full set)
      var totalWidth = slideW * 9;
      if (manualOffset < -totalWidth) manualOffset = manualOffset + totalWidth;
      if (manualOffset > 0) manualOffset = manualOffset - totalWidth;
      track.style.transform = 'translateX(' + manualOffset + 'px)';
      track.style.animation = 'none';
      // Resume auto-scroll after 3s of inactivity
      clearTimeout(window._engTimer);
      window._engTimer = setTimeout(function() {
        // Reset animation from current position
        var pct = Math.abs(manualOffset) / totalWidth;
        var remaining = (1 - pct) * 40;
        track.style.animation = 'none';
        track.style.transform = 'translateX(' + manualOffset + 'px)';
        // Use a keyframe restart trick
        track.classList.remove('paused');
        track.style.animation = '';
        track.style.transform = '';
      }, 3000);
    };
  })();

  function toggleAccordion(header) {
    const body = header.nextElementSibling;
    const icon = header.querySelector('.accordion-icon');
    const isOpen = body.classList.contains('open');
    // Close all
    document.querySelectorAll('.accordion-body').forEach(b => b.classList.remove('open'));
    document.querySelectorAll('.accordion-icon').forEach(i => i.classList.remove('open'));
    // Open this one if it was closed
    if (!isOpen) {
      body.classList.add('open');
      icon.classList.add('open');
    }
  }
  </script>
</body>
</html>
