<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SilentFoundry®</title>
  <link rel="icon" type="image/x-icon" href="favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Caesar+Dressing&family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="sf-styles.css" />
  <style>
    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 48px 80px;
      position: relative;
      overflow: hidden;
    }
    .hero-eyebrow,
    .hero-headline,
    .hero-sub {
      padding-left: 0;
      margin-left: 0;
      position: relative;
      width: 100%;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.squarespace-cdn.com/content/v1/69a7d61db6350c31d2475be3/d3800cd0-b166-4d4d-acae-185c89d7d2bc/speaker-4.jpg');
      background-size: cover;
      background-position: center;
      filter: brightness(0.35);
      transform: scale(1.05);
      animation: slowzoom 20s ease-out forwards;
    }
    @keyframes slowzoom {
      from { transform: scale(1.08); }
      to   { transform: scale(1.0); }
    }
    .hero-eyebrow {
      position: relative;
      font-size: 0.72rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 24px;
      opacity: 0;
      animation: fadein 1s 0.3s forwards;
    }
    .hero-headline {
      position: relative;
      font-family: var(--font-display);
      font-size: clamp(2.8rem, 7vw, 9rem);
      line-height: 0.92;
      text-transform: uppercase;
      color: var(--white);
      opacity: 0;
      animation: fadein 1s 0.5s forwards;
    }
    .hero-headline-top {
      display: block;
      font-family: 'Bebas Neue', sans-serif;
      color: rgba(240,235,224,0.15);
      letter-spacing: 0.22em;
      font-size: 0.65em;
    }
    .hero-headline-bottom {
      display: block;
      font-family: 'Bebas Neue', sans-serif;
      color: rgba(240,235,224,0.62);
      letter-spacing: 0.14em;
      font-size: 0.9em;
      margin-top: 0.1em;
    }
    .hero-sub {
      position: relative;
      margin-top: 32px;
      max-width: 520px;
      font-size: 1rem;
      line-height: 1.65;
      color: rgba(244,241,236,0.65);
      opacity: 0;
      animation: fadein 1s 0.8s forwards;
    }
    .hero-scroll {
      position: absolute;
      bottom: 80px;
      right: 48px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      opacity: 0;
      animation: fadein 1s 1.2s forwards;
    }
    .hero-scroll span {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      writing-mode: vertical-rl;
      color: var(--mid);
    }
    .scroll-line {
      width: 1px;
      height: 60px;
      background: linear-gradient(to bottom, var(--accent), transparent);
      animation: pulse-line 2s infinite;
    }
    @keyframes pulse-line { 0%,100%{opacity:0.4}50%{opacity:1} }
    @keyframes fadein {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── SECTIONS ── */
    section { padding: 120px 48px; }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(3rem, 7vw, 7rem);
      line-height: 0.92;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: rgba(244,241,236,0.82);
    }
    .section-title em {
      font-family: var(--font-display);
      font-style: normal;
      color: rgba(200,169,110,0.65);
      letter-spacing: 0.14em;
    }

    /* ── INTRO ── */
    .intro {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .intro-image {
      position: relative;
      overflow: hidden;
      aspect-ratio: 4/5;
    }
    .intro-image img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: brightness(0.85) contrast(1.1);
      transition: transform 0.8s ease;
    }
    .intro-image:hover img { transform: scale(1.04); }
    .intro-image::after {
      content: '';
      position: absolute;
      inset: 0;
      border: 1px solid rgba(200,169,110,0.2);
    }
    .intro-text p {
      font-size: clamp(0.9rem, 1.2vw, 1.05rem);
      line-height: 1.8;
      color: rgba(244,241,236,0.6);
      margin-bottom: 20px;
      font-weight: 300;
    }
    .intro-text p strong { color: rgba(244,241,236,0.85); font-weight: 400; }

    /* ── CASE STUDY ── */
    .case-study {
      background: var(--cream);
      color: var(--black);
    }
    .case-study .label { color: #8a6e3a; }
    .case-study .section-title { color: rgba(10,10,10,0.75); }
    .case-study .section-title em { color: rgba(138,110,58,0.7); }
    .case-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      margin-top: 72px;
      align-items: start;
    }
    .case-img { overflow: hidden; }
    .case-img img {
      width: 100%;
      aspect-ratio: 16/10;
      object-fit: cover;
      display: block;
      transition: transform 0.8s ease;
    }
    .case-img:hover img { transform: scale(1.03); }
    .case-body h3 {
      font-family: var(--font-display);
      font-size: 3rem;
      letter-spacing: 0.14em;
      line-height: 1;
      margin-bottom: 20px;
      color: rgba(10,10,10,0.75);
    }
    .case-body p {
      font-size: 0.95rem;
      line-height: 1.8;
      color: rgba(10,10,10,0.65);
      margin-bottom: 16px;
    }
    .case-text {
      display: block;
      margin-top: 48px;
      margin-left: 0;
      margin-right: auto;
      padding-top: 64px;
      border-top: 1px solid rgba(138,110,58,0.2);
      text-align: left;
      max-width: 680px;
    }
    .case-text p:first-child {
      font-family: var(--font-body);
      font-style: normal;
      font-size: clamp(0.9rem, 1.2vw, 1.05rem);
      line-height: 1.8;
      color: rgba(10,10,10,0.6);
      margin: 0 0 20px 0;
      padding-left: 0;
      border-left: none;
      text-align: left;
      font-weight: 300;
    }
    .case-note {
      font-family: var(--font-display);
      font-style: normal;
      font-size: 0.82rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #8a6e3a;
      margin: 0;
      padding-left: 0;
      display: block;
    }
    .translation-grid {
      margin-top: 48px;
    }

    /* ── HOW IT WORKS ── */
    .steps {
      margin-top: 80px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    .step {
      border: 1px solid rgba(244,241,236,0.08);
      padding: 48px 36px;
      transition: background 0.3s;
    }
    .step:hover { background: rgba(200,169,110,0.06); }
    .step-num {
      font-family: var(--font-display);
      font-size: 5rem;
      line-height: 1;
      color: rgba(200,169,110,0.15);
      margin-bottom: 24px;
    }
    .step h4 {
      font-family: var(--font-display);
      font-size: 1.6rem;
      letter-spacing: 0.14em;
      margin-bottom: 14px;
      text-transform: uppercase;
      color: rgba(244,241,236,0.75);
    }
    .step p {
      font-size: 0.88rem;
      line-height: 1.75;
      color: rgba(244,241,236,0.5);
    }

    /* ── VALUE ── */
    .value { background: #111; }
    .value-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2px;
      margin-top: 80px;
    }
    .value-card {
      padding: 56px 48px;
      border: 1px solid rgba(244,241,236,0.06);
      position: relative;
      overflow: hidden;
      transition: border-color 0.3s;
    }
    .value-card:hover { border-color: rgba(200,169,110,0.3); }
    .value-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 3px; height: 0;
      background: var(--accent);
      transition: height 0.4s ease;
    }
    .value-card:hover::before { height: 100%; }
    .value-card h4 {
      font-family: var(--font-display);
      font-size: 1.8rem;
      letter-spacing: 0.14em;
      margin-bottom: 20px;
      color: rgba(200,169,110,0.7);
      text-transform: uppercase;
    }
    .value-card p {
      font-size: 0.9rem;
      line-height: 1.8;
      color: rgba(244,241,236,0.55);
    }

    /* ── FEATURED ── */
    .featured-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      margin-top: 72px;
    }
    .featured-img { overflow: hidden; position: relative; }
    .featured-img img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
      filter: brightness(0.9);
      transition: transform 0.8s ease;
    }
    .featured-img:hover img { transform: scale(1.04); }
    .featured-img::before {
      content: 'FEATURED PROJECT';
      position: absolute;
      top: 24px; left: 24px;
      z-index: 2;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      color: var(--accent);
      background: rgba(10,10,10,0.7);
      padding: 6px 14px;
    }
    .featured-text h3 {
      font-family: var(--font-display);
      font-size: clamp(3rem, 5vw, 5rem);
      line-height: 0.92;
      letter-spacing: 0.14em;
      margin-bottom: 28px;
      text-transform: uppercase;
      color: rgba(244,241,236,0.82);
    }
    .featured-text p {
      font-size: 0.95rem;
      line-height: 1.8;
      color: rgba(244,241,236,0.6);
      margin-bottom: 16px;
    }
    .featured-note { color: var(--accent) !important; font-size: 0.82rem !important; letter-spacing: 0.1em; text-transform: uppercase; }

    /* ── LOGOS ── */
    .logos {
      background: #0d0d0d;
      padding: 80px 48px;
      text-align: center;
    }
    .logos .label { margin-bottom: 48px; }
    .logo-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 72px 16px;
      align-items: center;
      justify-items: center;
    }
    .logo-grid img {
      max-height: 24px;
      max-width: 150px;
      object-fit: contain;
      filter: brightness(0) invert(1);
      opacity: 0.35;
      transition: opacity 0.3s;
    }
    .logo-grid img:hover { opacity: 0.75; }

    /* ── FUNDS ── */
    .funds { background: var(--cream); color: var(--black); }
    .funds .label { color: #8a6e3a; }
    .funds .section-title { color: rgba(10,10,10,0.75); }
    .funds-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      margin-top: 72px;
    }
    .fund-card {
      background: rgba(10,10,10,0.04);
      border: 1px solid rgba(10,10,10,0.1);
      overflow: hidden;
      transition: border-color 0.3s;
    }
    .fund-card:hover { border-color: #8a6e3a; }
    .fund-img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
      filter: brightness(0.85) grayscale(0.2);
      transition: transform 0.6s ease;
    }
    .fund-card:hover .fund-img { transform: scale(1.04); }
    .fund-body { padding: 36px 32px; }
    .fund-tag {
      font-size: 0.65rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #8a6e3a;
      margin-bottom: 12px;
    }
    .fund-body h3 {
      font-family: var(--font-display);
      font-size: 2rem;
      letter-spacing: 0.14em;
      margin-bottom: 16px;
      color: rgba(10,10,10,0.75);
      text-transform: uppercase;
    }
    .fund-body p {
      font-size: 0.88rem;
      line-height: 1.75;
      color: rgba(10,10,10,0.6);
    }

    /* ── CTA ── */
    .cta {
      background: var(--accent);
      color: var(--black);
      text-align: center;
      padding: 120px 48px;
    }
    .cta .section-title { color: rgba(10,10,10,0.75); }
    .cta .section-title em { color: rgba(10,10,10,0.45); font-family: var(--font-display); font-style: normal; letter-spacing: 0.14em; }
    .cta p {
      margin-top: 28px;
      font-size: 1rem;
      color: rgba(10,10,10,0.6);
      max-width: 500px;
      margin-inline: auto;
      line-height: 1.7;
    }
    .btn {
      display: inline-block;
      margin-top: 48px;
      padding: 16px 48px;
      border: 2px solid var(--black);
      color: var(--black);
      text-decoration: none;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      transition: background 0.25s, color 0.25s;
    }
    .btn:hover { background: var(--black); color: var(--accent); }


    /* ── TRANSLATION GRID ── */
    .translation-grid {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 0 40px;
      align-items: center;
      margin-top: 64px;
    }
    .translation-side { text-align: center; }
    .translation-label {
      font-size: 0.65rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #8a6e3a;
      margin-bottom: 16px;
    }
    .translation-img {
      overflow: hidden;
      aspect-ratio: 4/3;
      position: relative;
    }
    .translation-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.6s ease;
    }
    .translation-img:hover img { transform: scale(1.04); }
    .translation-caption {
      margin-top: 16px;
      font-size: 0.8rem;
      line-height: 1.6;
      color: rgba(10,10,10,0.5);
    }
    .translation-arrow {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      color: #8a6e3a;
    }
    .arrow-line {
      width: 1px;
      height: 40px;
      background: #8a6e3a;
      opacity: 0.4;
    }
    .arrow-label {
      font-size: 0.62rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      text-align: center;
      color: #8a6e3a;
      line-height: 1.5;
    }
    .arrow-head {
      font-size: 1.4rem;
      color: #8a6e3a;
    }
    .case-text {
      max-width: 680px;
      margin: 40px auto 0;
      text-align: left;
    }
    .case-text p {
      font-size: 0.95rem;
      line-height: 1.8;
      color: rgba(10,10,10,0.6);
      margin-bottom: 12px;
    }

    /* ── SWITCH ECOSYSTEM ── */
    .switch-grid {
      display: grid;
      grid-template-columns: 1fr auto 1.6fr;
      gap: 0 40px;
      align-items: start;
    }
    .switch-origin { text-align: center; }
    .switch-origin-img {
      overflow: hidden;
      aspect-ratio: 4/3;
    }
    .switch-origin-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.6s ease;
    }
    .switch-origin-img:hover img { transform: scale(1.04); }
    .switch-ecosystem { }
    .ecosystem-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 16px;
    }
    .ecosystem-item {
      position: relative;
      overflow: hidden;
      aspect-ratio: 1/1;
      background: #111;
    }
    .ecosystem-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: brightness(0.85);
      transition: transform 0.6s ease, filter 0.4s ease;
    }
    .ecosystem-item:hover img { transform: scale(1.06); filter: brightness(1); }
    .ecosystem-item span {
      position: absolute;
      bottom: 8px;
      left: 0; right: 0;
      text-align: center;
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .switch-ecosystem .translation-caption {
      color: rgba(244,241,236,0.35);
      margin-top: 16px;
      text-align: center;
    }

    /* Mobile */
    @media (max-width: 900px) {
      .translation-grid,
      .switch-grid {
        grid-template-columns: 1fr;
        gap: 32px;
      }
      .translation-arrow { flex-direction: row; }
      .arrow-line { width: 40px; height: 1px; }
      .ecosystem-grid { grid-template-columns: repeat(3, 1fr); }
    }

    /* ══════════════════════════════
       MOBILE
       ══════════════════════════════ */
    @media (max-width: 900px) {
      section { padding: 80px 24px; }
      .hero { padding: 0 24px 60px; }
      .hero-scroll { display: none; }

      .intro { grid-template-columns: 1fr; gap: 40px; }
      .case-grid { grid-template-columns: 1fr; gap: 40px; }
      .steps { grid-template-columns: 1fr 1fr; }
      .value-grid { grid-template-columns: 1fr; }
      .featured-inner { grid-template-columns: 1fr; gap: 40px; }
      .funds-grid { grid-template-columns: 1fr; }
      .logo-grid { gap: 28px 36px; }
      .cta { padding: 80px 24px; }
      .logos { padding: 60px 24px; }
    }
    @media (max-width: 600px) {
      .steps { grid-template-columns: 1fr; }
      .value-card { padding: 36px 28px; }
    }

    /* ── TRANSLATION LAYOUT ── */
    .translation-intro {
      max-width: 680px;
      margin: 32px 0 56px;
    }
    .translation-intro p {
      font-size: 0.95rem;
      line-height: 1.8;
      color: rgba(10,10,10,0.65);
    }
    .translation-grid {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 0 40px;
      align-items: center;
      margin-top: 8px;
    }
    .translation-col { display: flex; flex-direction: column; gap: 16px; }
    .translation-label {
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #8a6e3a;
    }
    .translation-img {
      overflow: hidden;
      position: relative;
    }
    .translation-img img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
      transition: transform 0.6s ease;
    }
    .translation-img:hover img { transform: scale(1.03); }
    .translation-img.dark-bg { background: #111; }
    .translation-img.light-bg { background: #f0ede8; }
    .translation-tag {
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(10,10,10,0.45);
    }
    .translation-arrow {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding: 0 8px;
    }
    .arrow-line {
      width: 1px;
      height: 60px;
      background: linear-gradient(to bottom, transparent, #8a6e3a, transparent);
    }
    .arrow-label {
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #8a6e3a;
      text-align: center;
      line-height: 1.6;
    }
    .arrow-head {
      font-size: 1.2rem;
      color: #8a6e3a;
    }

    /* ── SWITCH ECOSYSTEM ── */
    .switch-grid {
      display: grid;
      grid-template-columns: 1fr auto 1.6fr;
      gap: 0 40px;
      align-items: start;
    }
    .switch-origin { display: flex; flex-direction: column; gap: 16px; }
    .switch-origin-img {
      overflow: hidden;
      background: #111;
    }
    .switch-origin-img img {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      object-position: center;
      display: block;
      transition: transform 0.6s ease;
    }
    .switch-origin-img:hover img { transform: scale(1.03); }
    .switch-ecosystem { display: flex; flex-direction: column; gap: 16px; }
    .ecosystem-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 6px;
    }
    .eco-item {
      display: flex;
      flex-direction: column;
      gap: 0;
      background: #111;
      overflow: hidden;
    }
    .eco-item img {
      width: 100%;
      aspect-ratio: 2/3;
      object-fit: cover;
      display: block;
      transition: transform 0.6s ease;
      filter: brightness(0.92);
    }
    .eco-item:hover img { transform: scale(1.04); filter: brightness(1.05); }
    .eco-item span {
      font-size: 0.6rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(244,241,236,0.45);
      padding: 14px 16px;
      background: #0d0d0d;
    }

    /* Mobile */
    @media (max-width: 900px) {
      .translation-grid { grid-template-columns: 1fr; gap: 32px 0; }
      .translation-arrow { flex-direction: row; padding: 8px 0; }
      .arrow-line { width: 60px; height: 1px; }
      .switch-grid { grid-template-columns: 1fr; gap: 32px 0; }
      .ecosystem-grid { grid-template-columns: repeat(3, 1fr); }
    }

    /* ── FACTORY BREAK ── */
    .factory-break {
      position: relative;
      width: 100%;
      height: 60vh;
      overflow: hidden;
    }
    .factory-break img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      filter: brightness(0.55);
      transform: scale(1.02);
      transition: transform 8s ease;
    }
    .factory-break:hover img { transform: scale(1.0); }
    .factory-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .factory-overlay span {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 3vw, 3rem);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(244,241,236,0.85);
      text-align: center;
    }

    /* ── ENGINEERING SECTION B ── */
    .eng-section {
      padding-top: 80px;
      margin-top: 120px;
      border-top: 1px solid rgba(244,241,236,0.08);
    }

    /* Top grid: left | gold divider | right */
    .eng-top {
      display: grid;
      grid-template-columns: 1fr 1px 1fr;
      gap: 0;
      align-items: end;
      margin-bottom: 52px;
    }
    .eng-top-divider {
      width: 1px;
      align-self: stretch;
      margin: 0 52px;
      background: linear-gradient(to bottom,
        transparent 0%,
        rgba(200,169,110,0.0) 5%,
        rgba(200,169,110,0.18) 25%,
        rgba(200,169,110,0.28) 50%,
        rgba(200,169,110,0.18) 75%,
        rgba(200,169,110,0.0) 95%,
        transparent 100%
      );
    }
    .eng-left {}
    .eng-headline {
      font-family: var(--font-display);
      font-size: clamp(3rem, 5.5vw, 6rem);
      line-height: 0.88;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(244,241,236,0.82);
    }
    .eng-body {
      font-size: clamp(0.9rem, 1.2vw, 1.05rem);
      line-height: 1.8;
      color: rgba(244,241,236,0.5);
      font-weight: 300;
      max-width: 460px;
      margin-top: 28px;
      margin-bottom: 32px;
      padding-left: 2px;
    }
    .eng-pills {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      row-gap: 8px;
    }
    .eng-pill {
      display: inline-block;
      padding: 5px 14px;
      border: 0.5px solid rgba(200,169,110,0.3);
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
      transition: border-color 0.2s, color 0.2s;
    }
    .eng-pill:hover { border-color: var(--accent); color: var(--white); }
    .eng-pills-break {
      flex-basis: 100%;
      height: 0;
    }

    /* Right specs */
    .eng-specs {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding-left: 52px;
    }
    .eng-spec-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 14px 0;
      border-bottom: 0.5px solid rgba(244,241,236,0.07);
    }
    .eng-spec-row:first-child { border-top: 0.5px solid rgba(244,241,236,0.07); }
    .eng-spec-label {
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(244,241,236,0.28);
    }
    .eng-spec-val {
      font-size: 0.82rem;
      color: rgba(244,241,236,0.65);
      text-align: right;
    }

    /* Carousel */
    .eng-carousel-outer {
      position: relative;
    }
    .eng-carousel-wrap {
      position: relative;
      overflow: hidden;
      width: 100%;
    }
    .eng-carousel-track {
      display: flex;
      gap: 2px;
      will-change: transform;
      animation: eng-scroll 40s linear infinite;
    }
    .eng-carousel-track.paused {
      animation-play-state: paused;
    }
    @keyframes eng-scroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .eng-slide {
      flex: 0 0 calc(33.333vw - 2px);
      max-width: 560px;
      min-width: 320px;
      position: relative;
      overflow: hidden;
    }
    .eng-slide img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
      filter: brightness(0.65);
      transition: filter 0.5s ease;
    }
    .eng-slide:hover img { filter: brightness(0.85); }
    .eng-slide-info {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 20px 20px 16px;
      background: linear-gradient(to top, rgba(10,10,10,0.92) 0%, transparent 100%);
    }
    .eng-slide-num {
      font-family: var(--font-display);
      font-size: 2.2rem;
      color: rgba(200,169,110,0.15);
      line-height: 1;
      display: block;
    }
    .eng-slide-tag {
      font-size: 0.58rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
      display: block;
      margin-bottom: 3px;
    }
    .eng-slide-name {
      font-family: var(--font-display);
      font-size: 0.9rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(244,241,236,0.82);
    }

    /* Carousel buttons */
    .eng-carousel-btn {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
      background: rgba(10,10,10,0.7);
      border: 0.5px solid rgba(200,169,110,0.25);
      color: rgba(244,241,236,0.7);
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s, color 0.2s;
      font-size: 1.1rem;
      line-height: 1;
    }
    .eng-carousel-btn:hover {
      background: rgba(200,169,110,0.15);
      border-color: rgba(200,169,110,0.6);
      color: var(--accent);
    }
    .eng-carousel-btn-prev { left: 16px; }
    .eng-carousel-btn-next { right: 16px; }

    @media (max-width: 900px) {
      .eng-top { grid-template-columns: 1fr; }
      .eng-top-divider { display: none; }
      .eng-specs { padding-left: 0; margin-top: 32px; }
      .eng-slide { flex: 0 0 80vw; }
      .eng-carousel-track { animation-duration: 30s; }
    }

    /* ── FACTORY DUO ── */
    .factory-duo {
      position: relative;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      height: 55vh;
      overflow: hidden;
    }
    .factory-duo-img {
      overflow: hidden;
      position: relative;
    }
    .factory-duo-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: brightness(0.5);
      transition: transform 8s ease, filter 0.5s ease;
      transform: scale(1.03);
    }
    .factory-duo:hover .factory-duo-img img {
      transform: scale(1.0);
      filter: brightness(0.6);
    }
    .factory-duo-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
    }
    .factory-duo-overlay span {
      font-family: var(--font-display);
      font-size: clamp(1.2rem, 2.5vw, 2.5rem);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(244,241,236,0.9);
      text-align: center;
    }

    @media (max-width: 900px) {
      .engineering-strip { grid-template-columns: 1fr; gap: 40px; margin-top: 48px; }
      .factory-duo { grid-template-columns: 1fr; height: 70vh; }
      .factory-duo-img:last-of-type { display: none; }
    }

    /* ── FACTORY SOLO ── */
    .factory-solo {
      width: 100%;
      height: 80vh;
      overflow: hidden;
      position: relative;
    }
    .factory-solo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      filter: brightness(0.7);
      transform: scale(1.02);
      transition: transform 8s ease;
    }
    .factory-solo:hover img { transform: scale(1.0); }

    /* ── ACCORDION ── */
    .accordion-steps {
      display: flex;
      flex-direction: column;
      margin-top: 60px;
    }
    .accordion-item {
      border-bottom: 1px solid rgba(244,241,236,0.1);
    }
    .accordion-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 28px 0;
      cursor: pointer;
      user-select: none;
    }
    .accordion-header:hover .accordion-title { color: var(--accent); }
    .accordion-left {
      display: flex;
      align-items: center;
      gap: 32px;
    }
    .accordion-num {
      font-family: var(--font-display);
      font-size: 0.75rem;
      letter-spacing: 0.25em;
      color: rgba(200,169,110,0.5);
      min-width: 28px;
    }
    .accordion-title {
      font-family: var(--font-display);
      font-size: 2.5rem;
      letter-spacing: 0.14em;
      color: rgba(244,241,236,0.75);
      transition: color 0.2s;
      line-height: 1;
      text-transform: uppercase;
    }
    .accordion-icon {
      font-size: 1.4rem;
      color: var(--accent);
      transition: transform 0.3s ease;
      min-width: 24px;
      text-align: right;
      font-weight: 300;
    }
    .accordion-icon.open { transform: rotate(45deg); }
    .accordion-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease, padding 0.3s ease;
      padding-left: 60px;
    }
    .accordion-body.open {
      max-height: 200px;
      padding-bottom: 28px;
    }
    .accordion-body p {
      font-size: 0.92rem;
      line-height: 1.8;
      color: rgba(244,241,236,0.5);
      max-width: 500px;
    }
  </style>
</head>
<body>

  <!-- MOBILE MENU -->
  <div class="mobile-menu">
    <a href="index.html">Home</a>
    <a href="index.html#how">How It Works</a>
    <a href="index.html#funds">Funds</a>
    <a href="index.html#featured">Projects</a>
    <a href="sf-team.html">Team</a>
    <a href="sf-contact.html">Contact</a>
  </div>

  <!-- NAV -->
  <nav>
    <a href="index.html" class="nav-logo">
      <span>Silent</span>
      <span>Foundry<span class="reg">®</span></span>
    </a>
    <ul class="nav-links">
      <li><a href="#how">How It Works</a></li>
      <li><a href="#funds">Investors</a></li>
      <li><a href="#featured">Projects</a></li>
      <li><a href="sf-team.html">Team</a></li>
      <li><a href="sf-contact.html">Contact</a></li>
    </ul>
    <button class="nav-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <p class="hero-eyebrow">A cross-border venture studio</p>
    <h1 class="hero-headline"><span class="hero-headline-top">INTANGIBLE BRANDS.</span><span class="hero-headline-bottom">REAL PRODUCTS.</span></h1>
    <div class="hero-scroll">
      <div class="scroll-line"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee-wrap">
    <div class="marquee-track">
      <span>Brand Translation</span><span>—</span><span>Product Engineering</span><span>—</span><span>Industrial Design</span><span>—</span><span>Cross-Border Manufacturing</span><span>—</span><span>Venture Creation</span><span>—</span><span>Strategic Exits</span><span>—</span><span>Brand Translation</span><span>—</span><span>Product Engineering</span><span>—</span><span>Industrial Design</span><span>—</span><span>Cross-Border Manufacturing</span><span>—</span><span>Venture Creation</span><span>—</span><span>Strategic Exits</span>
    </div>
  </div>

  <!-- INTRO -->
  <section class="intro">
    <div class="intro-image reveal-left">
      <img src="https://images.squarespace-cdn.com/content/v1/69a7d61db6350c31d2475be3/2a29c509-c624-42d1-999f-2df3e2f2127d/master+at+work+copy.jpg" alt="Craftsman at work" />
    </div>
    <div class="intro-text">
      <p class="label reveal">The Problem</p>
      <h2 class="section-title reveal" style="font-size:clamp(2.5rem,5vw,4.5rem);margin-bottom:40px;">Concepts<br/>are <em>cheap.</em><br/>Products are hard.</h2>
      <p class="reveal reveal-delay-1" style="color: rgba(244,241,236,0.6); font-size: clamp(0.9rem,1.2vw,1.05rem); line-height: 1.8; margin-bottom: 20px; font-weight: 300;">Modern tools can generate concepts instantly. Building premium products around a brand is much harder.</p>
      <p class="reveal reveal-delay-2" style="color: rgba(244,241,236,0.6); font-size: clamp(0.9rem,1.2vw,1.05rem); line-height: 1.8; margin-bottom: 16px; font-weight: 300;">Most creator, celebrity, service, and heritage brands have the audience to expand beyond merch, but not the industrial system to do it properly.</p>
      <p class="reveal reveal-delay-3" style="font-family:'Bebas Neue',sans-serif;font-size:0.82rem;letter-spacing:0.14em;text-transform:uppercase;color:#8a6e3a;margin:0;display:block;">That is where we come in.</p>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CASE STUDY -->
  <section class="case-study">
    <p class="label reveal">Case Study</p>
    <h2 class="section-title reveal">Rock and roll<br/><em>never dies.</em></h2>

    <div class="translation-grid reveal">
      <!-- Before -->
      <div class="translation-side">
        <div class="translation-label">Origin</div>
        <div class="translation-img">
          <img src="amp_marshall_original.jpeg" alt="Marshall Amp" />
        </div>
        <p class="translation-caption">Guitar amplifier<br/>Est. 1962</p>
      </div>

      <!-- Arrow -->
      <div class="translation-arrow">
        <div class="arrow-line"></div>
        <div class="arrow-label">Brand<br/>Translation</div>
        <div class="arrow-head">→</div>
      </div>

      <!-- After -->
      <div class="translation-side">
        <div class="translation-label">Expansion</div>
        <div class="translation-img">
          <img src="https://images.squarespace-cdn.com/content/v1/69a7d61db6350c31d2475be3/fbdbf93b-ce79-4a91-9ac6-aac148248ca6/marshall_homeline-III-family_0070_alt1_white-bg-1-1600x1200.jpg" alt="Marshall Speakers" />
        </div>
        <p class="translation-caption">Home & portable audio<br/>New market unlocked</p>
      </div>
    </div>

    <div class="case-text reveal">
      <p style="color: rgba(10,10,10,0.6);">Marshall Amplification was iconic, but the guitar and amplifier market was shrinking. Zound Industries translated Marshall's DNA into home and personal audio, opening a much larger market. They did not just add a logo — they industrialized the brand's soul.</p>
      <p class="case-note">This is the model we replicate.</p>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how">
    <p class="label reveal">The Process</p>
    <h2 class="section-title reveal">How it<br/><em>works.</em></h2>
    <div class="accordion-steps reveal">
      <div class="accordion-item">
        <div class="accordion-header" onclick="toggleAccordion(this)">
          <div class="accordion-left"><span class="accordion-num">01</span><span class="accordion-title">Identify</span></div>
          <span class="accordion-icon">+</span>
        </div>
        <div class="accordion-body open"><p>Demand shifts and product gaps in China.</p></div>
      </div>
      <div class="accordion-item">
        <div class="accordion-header" onclick="toggleAccordion(this)">
          <div class="accordion-left"><span class="accordion-num">02</span><span class="accordion-title">Select</span></div>
          <span class="accordion-icon">+</span>
        </div>
        <div class="accordion-body"><p>High-DNA brands suited to premium productization.</p></div>
      </div>
      <div class="accordion-item">
        <div class="accordion-header" onclick="toggleAccordion(this)">
          <div class="accordion-left"><span class="accordion-num">03</span><span class="accordion-title">Design</span></div>
          <span class="accordion-icon">+</span>
        </div>
        <div class="accordion-body"><p>Product concepts built around the brand's DNA.</p></div>
      </div>
      <div class="accordion-item">
        <div class="accordion-header" onclick="toggleAccordion(this)">
          <div class="accordion-left"><span class="accordion-num">04</span><span class="accordion-title">Structure</span></div>
          <span class="accordion-icon">+</span>
        </div>
        <div class="accordion-body"><p>Deal structures and, where relevant, direct investment.</p></div>
      </div>
      <div class="accordion-item">
        <div class="accordion-header" onclick="toggleAccordion(this)">
          <div class="accordion-left"><span class="accordion-num">05</span><span class="accordion-title">Execute</span></div>
          <span class="accordion-icon">+</span>
        </div>
        <div class="accordion-body"><p>Design, engineer, manufacture, and launch.</p></div>
      </div>
      <div class="accordion-item">
        <div class="accordion-header" onclick="toggleAccordion(this)">
          <div class="accordion-left"><span class="accordion-num">06</span><span class="accordion-title">Exit</span></div>
          <span class="accordion-icon">+</span>
        </div>
        <div class="accordion-body"><p>Earlier liquidity through dedicated SPVs.</p></div>
      </div>
    </div>

    <!-- ENGINEERING SECTION -->
    <div class="eng-section reveal">

      <!-- Top: headline + body + pills LEFT | gold line | specs RIGHT -->
      <div class="eng-top">
        <div class="eng-left">
          <p class="label" style="color:var(--accent);margin-bottom:20px;">In-House Engineering</p>
          <h2 class="eng-headline">We don't brief<br/>studios. We build<br/>the files.</h2>
          <p class="eng-body">From custom PCB layouts to 6061 aluminium battery enclosures, our team owns the full engineering stack — mechanical, electrical, and manufacturing. Every product leaves our hands production-ready.</p>
          <div class="eng-pills">
            <span class="eng-pill">Mechanical CAD</span>
            <span class="eng-pill">Electronics & PCB</span>
            <span class="eng-pill">CNC & Tooling</span>
            <span class="eng-pill">Industrial Design</span>
            <div class="eng-pills-break"></div>
            <span class="eng-pill">Firmware</span>
            <span class="eng-pill">DFM</span>
            <span class="eng-pill">Supply Chain</span>
            <span class="eng-pill">Prototyping</span>
            <span class="eng-pill">Systems Integration</span>
            <div class="eng-pills-break"></div>
            <span class="eng-pill">Thermal Management</span>
            <span class="eng-pill">Structural Analysis</span>
            <span class="eng-pill">Battery Systems</span>
            <span class="eng-pill">Homologation</span>
            <span class="eng-pill">Wiring Harness</span>
          </div>
        </div>

        <div class="eng-top-divider"></div>

        <div class="eng-specs">
          <div class="eng-spec-row">
            <span class="eng-spec-label">Product Categories</span>
            <span class="eng-spec-val">EV · Consumer · Lifestyle</span>
          </div>
          <div class="eng-spec-row">
            <span class="eng-spec-label">Engineering Disciplines</span>
            <span class="eng-spec-val">Mechanical · Electrical · Software</span>
          </div>
          <div class="eng-spec-row">
            <span class="eng-spec-label">Manufacturing</span>
            <span class="eng-spec-val">CNC · Casting · Sheet Metal</span>
          </div>
          <div class="eng-spec-row">
            <span class="eng-spec-label">Team Background</span>
            <span class="eng-spec-val">Ex-Yamaha · Automotive · Aerospace</span>
          </div>
          <div class="eng-spec-row">
            <span class="eng-spec-label">Pipeline</span>
            <span class="eng-spec-val">Concept → CAD → CNC → Production</span>
          </div>
        </div>
      </div>

      <!-- Infinite carousel with prev/next buttons -->
      <div class="eng-carousel-outer">
        <button class="eng-carousel-btn eng-carousel-btn-prev" onclick="engCarouselStep(-1)" aria-label="Previous">&#8592;</button>
        <button class="eng-carousel-btn eng-carousel-btn-next" onclick="engCarouselStep(1)" aria-label="Next">&#8594;</button>
        <div class="eng-carousel-wrap" id="engWrap">
          <div class="eng-carousel-track" id="engTrack">
            <!-- Set 1 -->
            <div class="eng-slide"><img src="battery_gold.png" alt="Engineering Drawing" style="object-position:center top;" /><div class="eng-slide-info"><span class="eng-slide-num">01</span><span class="eng-slide-tag">Engineering Drawing</span><span class="eng-slide-name">Battery Pack Layout</span></div></div>
            <div class="eng-slide"><img src="6D44EE49-2285-4AA6-B846-2620B8F917EB_1_102_o.jpeg" alt="PCB Layout" /><div class="eng-slide-info"><span class="eng-slide-num">02</span><span class="eng-slide-tag">Electronics</span><span class="eng-slide-name">PCB Layout — VCU v1.6</span></div></div>
            <div class="eng-slide"><img src="cad-screen.jpg" alt="CAD 3D Model" /><div class="eng-slide-info"><span class="eng-slide-num">03</span><span class="eng-slide-tag">3D Modelling</span><span class="eng-slide-name">CAD Digital Twin</span></div></div>
            <div class="eng-slide"><img src="frame_factory-157.jpg" alt="Engineer at workstation" /><div class="eng-slide-info"><span class="eng-slide-num">04</span><span class="eng-slide-tag">Engineering</span><span class="eng-slide-name">CAM Toolpath Programming</span></div></div>
            <div class="eng-slide"><img src="cnc_1-14.jpg" alt="CNC machined part" /><div class="eng-slide-info"><span class="eng-slide-num">05</span><span class="eng-slide-tag">CNC Machining</span><span class="eng-slide-name">Aluminium Billet Cut</span></div></div>
            <div class="eng-slide"><img src="cnc-cutting.jpg" alt="CNC cutting" /><div class="eng-slide-info"><span class="eng-slide-num">06</span><span class="eng-slide-tag">Precision Cutting</span><span class="eng-slide-name">5-Axis Machining</span></div></div>
            <div class="eng-slide"><img src="frame_factory-413.png" alt="CNC bed" /><div class="eng-slide-info"><span class="eng-slide-num">07</span><span class="eng-slide-tag">Tooling</span><span class="eng-slide-name">CNC Bed Setup</span></div></div>
            <div class="eng-slide"><img src="prototype_assembly.jpg" alt="Prototype assembly" /><div class="eng-slide-info"><span class="eng-slide-num">08</span><span class="eng-slide-tag">Assembly</span><span class="eng-slide-name">Battery Cell Integration</span></div></div>
